DAYTONA_API_KEY=           # from app.daytona.io → API Keys
OPENAI_API_KEY=            # from platform.openai.com → API Keys (starts with sk-...)
DAYTONA_SNAPSHOT=          # run snapshot_setup.py once to get this value

# Development flags (both false in production)
MOCK=false                 # true = skip scanning entirely, return canned response
LOCAL_PLAYWRIGHT=false     # true = run Playwright locally (no Daytona) for dev/testing
