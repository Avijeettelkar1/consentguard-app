DAYTONA_API_KEY=           # from app.daytona.io → API Keys
OPENAI_API_KEY=            # from platform.openai.com → API Keys (starts with sk-...)
DAYTONA_SNAPSHOT=          # Person 1 fills this after snapshot_setup.py runs

# Development flags
MOCK=false                 # set true to skip all real scanning (fastest local dev)
LOCAL_PLAYWRIGHT=false     # set true to run Playwright locally instead of Daytona
