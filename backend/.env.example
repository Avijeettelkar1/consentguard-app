DAYTONA_API_KEY=
DAYTONA_SNAPSHOT=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Hackathon partner tech (Reject-All Radar agent) ---
# OpenAI = the AI auditor's brain (preferred provider; earns the partner-tech bonus).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Tavily = the agent's eyes on the web (industry -> real sites). Blank = curated fallback list.
TAVILY_API_KEY=
# Which LLM judges the trackers: auto (OpenAI, then Claude, then offline rules) | openai | claude | local
LLM_PROVIDER=auto
# How many sites to scan in parallel during a raid.
RAID_CONCURRENCY=4
# Cognee = cross-site memory graph (optional bonus; local aggregation works without it).
COGNEE_ENABLED=false

# Set true to return canned demo data without scanning.
MOCK=false

# Set true to run a second scan after analysis for verification.
VERIFY_SCAN=false
